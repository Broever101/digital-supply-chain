graph LR
    %% Layer 1: Hardware
    HW[NVIDIA H100/B200/GB200<br/>AMD MI300X<br/>Groq LPU<br/>Cerebras WSE<br/>Google TPU]
    
    %% Layer 2: Virtualization & Cloud
    VIRT[MIG / Run:ai<br/>Time-slicing<br/>vGPU]
    CLOUD[CoreWeave<br/>AWS / Azure / GCP<br/>Lambda / Crusoe<br/>Modal / Baseten<br/>RunPod]
    
    %% Layer 3: Orchestration
    ORCH[Kubernetes + Volcano<br/>Ray Serve / Anyscale<br/>KServe / Seldon<br/>NVIDIA Dynamo<br/>NVIDIA NIM]
    
    %% Layer 4: Inference Engines
    ENGINE[vLLM<br/>SGLang<br/>llama.cpp / Ollama<br/>TensorRT-LLM<br/>MLX]
    
    %% Layer 5: Application & Control Plane
    APP[LiteLLM / OpenRouter<br/>Portkey / Helicone<br/>Stripe / Lago<br/>Langfuse / promptfoo]
    
    %% End User
    USER[Developer<br/>Coding Agents<br/>Consumer Apps]
    
    HW --> VIRT
    VIRT --> CLOUD
    CLOUD --> ORCH
    ORCH --> ENGINE
    ENGINE --> APP
    APP --> USER
    
    %% Edge bypass
    HW -.->|local inference| ENGINE

    style HW fill:#e1f5e1,stroke:#333,stroke-width:2px
    style CLOUD fill:#e1f0ff,stroke:#333,stroke-width:2px
    style ORCH fill:#fff4e1,stroke:#333,stroke-width:2px
    style ENGINE fill:#ffe1e1,stroke:#333,stroke-width:2px
    style APP fill:#f0e1ff,stroke:#333,stroke-width:2px
    style USER fill:#ffe1f5,stroke:#333,stroke-width:2px
